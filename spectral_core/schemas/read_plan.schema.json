{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.spectral-skills.local/spectral-reader/read_plan.schema.json",
  "title": "Spectral Reader Read Plan",
  "type": "object",
  "required": [
    "read_plan_id",
    "read_plan_version",
    "read_plan_status",
    "created_by",
    "source_path",
    "input_kind",
    "file_type",
    "read_mode",
    "preview_evidence",
    "decision_evidence",
    "required_confirmations",
    "execution_intent"
  ],
  "properties": {
    "read_plan_id": { "type": "string" },
    "read_plan_version": { "type": "string" },
    "read_plan_status": { "type": "string", "enum": ["draft", "confirmed", "provisional", "blocked"] },
    "created_by": { "type": "string" },
    "created_by_type": { "type": "string", "enum": ["agent", "user", "tool", "script", "unknown"] },
    "created_by_detail": { "type": ["string", "null"] },
    "source_preview_ref": { "type": ["string", "null"] },
    "source_path": { "type": ["string", "array"] },
    "source_base_dir": { "type": ["string", "null"] },
    "input_kind": { "type": "string", "enum": ["file", "folder", "multiple_files", "unknown"] },
    "file_type": { "type": ["string", "null"] },

    "encoding": { "type": ["string", "null"] },
    "delimiter": { "type": ["string", "null"] },
    "skiprows": { "type": ["integer", "array", "null"] },
    "header_row": { "type": ["integer", "null"] },
    "header_rows": { "type": "array", "items": { "type": "integer" } },
    "sheet_name": { "type": ["string", "null"] },
    "workbook": {
      "type": "object",
      "properties": {
        "path": { "type": ["string", "null"] },
        "file_type": { "type": ["string", "null"] },
        "engine": { "type": ["string", "null"] },
        "spectral_sheet": { "type": ["string", "null"] },
        "label_sheet": { "type": ["string", "null"] },
        "selected_sheet": { "type": ["string", "null"] },
        "sheet_index": { "type": ["integer", "null"] }
      },
      "additionalProperties": true
    },
    "sheet": {
      "type": "object",
      "properties": {
        "name": { "type": ["string", "null"] },
        "index": { "type": ["integer", "null"] },
        "skiprows": { "type": ["integer", "null"] },
        "header_row": { "type": ["integer", "null"] },
        "sample_orientation": { "type": ["string", "null"] },
        "sample_id_column": { "type": ["string", "null"] },
        "label_column": { "type": ["string", "null"] },
        "target_columns": { "type": "array", "items": { "type": "string" } },
        "metadata_columns": { "type": "array", "items": { "type": "string" } },
        "spectral_columns": { "type": "array", "items": { "type": "string" } },
        "band_axis_column": { "type": ["string", "integer", "null"] }
      },
      "additionalProperties": true
    },
    "variable_name": { "type": ["string", "null"] },
    "json_path": { "type": ["string", "null"] },
    "array_key": { "type": ["string", "null"] },
    "container": {
      "type": "object",
      "properties": {
        "path": { "type": ["string", "null"] },
        "file_type": { "type": ["string", "null"] },
        "x_var": { "type": ["string", "null"] },
        "y_var": { "type": ["string", "null"] },
        "sample_ids_var": { "type": ["string", "null"] },
        "band_axis_var": { "type": ["string", "null"] },
        "metadata_var": { "type": ["string", "null"] },
        "sample_orientation": { "type": ["string", "null"] },
        "allow_generated_sample_ids": { "type": ["boolean", "null"] },
        "allow_generated_band_axis": { "type": ["boolean", "null"] }
      },
      "additionalProperties": true
    },
    "variable_map": {
      "type": "object",
      "properties": {
        "X": { "type": ["string", "null"] },
        "y": { "type": ["string", "null"] },
        "sample_ids": { "type": ["string", "null"] },
        "band_axis": { "type": ["string", "null"] },
        "metadata": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "hierarchical_container": {
      "type": "object",
      "properties": {
        "path": { "type": ["string", "null"] },
        "file_type": { "type": ["string", "null"] },
        "x_path": { "type": ["string", "null"] },
        "y_path": { "type": ["string", "null"] },
        "sample_ids_path": { "type": ["string", "null"] },
        "band_axis_path": { "type": ["string", "null"] },
        "metadata_path": { "type": ["string", "null"] },
        "sample_orientation": { "type": ["string", "null"] },
        "allow_generated_sample_ids": { "type": ["boolean", "null"] },
        "allow_generated_band_axis": { "type": ["boolean", "null"] }
      },
      "additionalProperties": true
    },
    "dataset_map": {
      "type": "object",
      "properties": {
        "X": { "type": ["string", "null"] },
        "y": { "type": ["string", "null"] },
        "sample_ids": { "type": ["string", "null"] },
        "band_axis": { "type": ["string", "null"] },
        "metadata": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "folder_mode": { "type": ["string", "null"] },

    "read_mode": {
      "type": "string",
      "enum": ["matrix_file", "sample_files_folder", "external_label_alignment", "multi_sheet", "multi_variable", "json_table", "unknown"]
    },
    "sample_orientation": { "type": ["string", "null"], "enum": ["rows", "columns", "one_file_per_sample", "unknown", null] },
    "sample_axis": { "type": ["string", "integer", "null"] },
    "feature_axis": { "type": ["string", "integer", "null"] },
    "table_region": { "type": "object", "additionalProperties": true },
    "table_layout": {
      "type": "object",
      "properties": {
        "header_rows": { "type": "array", "items": { "type": "integer" } },
        "header_row": { "type": ["integer", "null"] },
        "skiprows": { "type": ["integer", "null"] },
        "data_start_row": { "type": ["integer", "null"] },
        "data_end_row": { "type": ["integer", "null"] },
        "spectral_start_column": { "type": ["string", "integer", "null"] },
        "spectral_end_column": { "type": ["string", "integer", "null"] },
        "spectral_columns": { "type": "array", "items": { "type": "string" } },
        "metadata_columns": { "type": "array", "items": { "type": "string" } },
        "label_column": { "type": ["string", "null"] },
        "target_columns": { "type": "array", "items": { "type": "string" } },
        "sample_id_column": { "type": ["string", "integer", "null"] }
      },
      "additionalProperties": true
    },
    "data_start_row": { "type": ["integer", "null"] },
    "data_end_row": { "type": ["integer", "null"] },
    "data_start_column": { "type": ["integer", "string", "null"] },
    "data_end_column": { "type": ["integer", "string", "null"] },

    "sample_id": { "$ref": "#/$defs/role_object" },
    "label": { "$ref": "#/$defs/role_object" },
    "target": { "$ref": "#/$defs/role_object" },
    "metadata": {
      "type": "object",
      "properties": {
        "columns": { "type": "array", "items": { "type": "string" } },
        "source": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "spectral_columns": {
      "type": "object",
      "properties": {
        "columns": { "type": "array", "items": { "type": "string" } },
        "start": { "type": ["string", "integer", "null"] },
        "end": { "type": ["string", "integer", "null"] },
        "source": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "band_axis": { "type": "object", "additionalProperties": true },
    "band_axis_source": {
      "type": "object",
      "properties": {
        "mode": { "type": ["string", "null"] },
        "file": { "type": ["string", "null"] },
        "column": { "type": ["string", "integer", "null"] },
        "unit": { "type": ["string", "null"] },
        "type": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "multi_target": {
      "type": "object",
      "properties": {
        "enabled": { "type": ["boolean", "null"] },
        "target_columns": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "samples_as_columns": { "$ref": "#/$defs/samples_as_columns" },
    "band_unit": { "type": ["string", "null"], "enum": ["nm", "cm-1", "index", "unknown", null] },
    "spectral_type": { "type": ["string", "null"] },
    "task_hint": { "type": ["string", "null"], "enum": ["classification", "regression", "multi_target_regression", "unsupervised", "unknown", null] },

    "label_file": { "$ref": "#/$defs/label_file" },
    "band_axis_file": { "$ref": "#/$defs/external_file" },
    "metadata_file": { "$ref": "#/$defs/external_file" },
    "external_validation_file": { "$ref": "#/$defs/external_file" },
    "alignment_plan": { "$ref": "#/$defs/alignment_plan" },

    "sample_file_pattern": { "type": ["string", "null"] },
    "sample_file_recursive": { "type": ["boolean", "null"] },
    "sample_file_columns": {
      "type": "object",
      "properties": {
        "band_axis": { "type": ["string", "integer", "null"] },
        "value": { "type": ["string", "integer", "null"] }
      },
      "additionalProperties": true
    },
    "sample_file_band_axis_column": { "type": ["string", "integer", "null"] },
    "sample_file_value_column": { "type": ["string", "integer", "null"] },
    "sample_file_reading": {
      "type": "object",
      "properties": {
        "encoding": { "type": ["string", "null"] },
        "delimiter": { "type": ["string", "null"] },
        "skiprows": { "type": ["integer", "null"] },
        "header_row": { "type": ["integer", "null"] }
      },
      "additionalProperties": true
    },
    "file_name_as_sample_id": { "type": ["boolean", "null"] },
    "file_name_as_label": { "type": ["boolean", "null"] },
    "folder_name_as_label": { "type": ["boolean", "null"] },
    "per_file_band_axis_policy": { "type": ["string", "null"] },

    "preview_evidence": { "type": "object", "additionalProperties": true },
    "decision_evidence": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "selected_fragments": { "type": "array", "items": { "type": "string" } },
    "selected_references": { "type": "array", "items": { "type": "string" } },
    "confidence_scores": { "type": "object", "additionalProperties": true },

    "required_confirmations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "recommended_confirmations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "confirmed_items": { "type": "array", "items": { "type": "string" } },
    "unresolved_items": { "type": "array", "items": { "type": "string" } },

    "execution_intent": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "write_package": { "type": "boolean" },
        "validation_level": { "type": "string" },
        "expected_backend": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "expected_outputs": { "type": "array", "items": { "type": "string" } },
    "blocked_reasons": { "type": "array", "items": { "type": "string" } },
    "downstream_readiness_hint": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "role_object": {
      "type": "object",
      "properties": {
        "source": { "type": ["string", "null"] },
        "column": { "type": ["string", "integer", "null"] },
        "columns": { "type": "array", "items": { "type": "string" } },
        "required": { "type": "boolean" },
        "status": { "type": ["string", "null"] },
        "evidence": { "type": "array" }
      },
      "additionalProperties": true
    },
    "external_file": {
      "type": "object",
      "properties": {
        "path": { "type": ["string", "null"] },
        "role": { "type": ["string", "null"] },
        "required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "label_file": {
      "type": "object",
      "properties": {
        "path": { "type": ["string", "null"] },
        "file_type": { "type": ["string", "null"] },
        "sheet_name": { "type": ["string", "null"] },
        "sheet_index": { "type": ["integer", "null"] },
        "encoding": { "type": ["string", "null"] },
        "delimiter": { "type": ["string", "null"] },
        "skiprows": { "type": ["integer", "null"] },
        "header_row": { "type": ["integer", "null"] },
        "sample_id_column": { "type": ["string", "null"] },
        "label_column": { "type": ["string", "null"] },
        "target_columns": { "type": "array", "items": { "type": "string" } },
        "metadata_columns": { "type": "array", "items": { "type": "string" } },
        "role": { "type": ["string", "null"] },
        "required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "samples_as_columns": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "band_axis_column": { "type": ["string", "integer", "null"] },
        "sample_id_source": { "type": ["string", "null"] },
        "sample_id_row": { "type": ["integer", "null"] },
        "label_row": { "type": ["integer", "null"] },
        "metadata_rows": { "type": "array", "items": { "type": "integer" } },
        "data_start_row": { "type": ["integer", "null"] },
        "data_end_row": { "type": ["integer", "null"] },
        "sample_start_column": { "type": ["string", "integer", "null"] },
        "sample_end_column": { "type": ["string", "integer", "null"] },
        "transpose_required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "alignment_plan": {
      "type": "object",
      "properties": {
        "join_key": { "type": ["string", "null"] },
        "left_source": { "type": ["string", "null"] },
        "right_source": { "type": ["string", "null"] },
        "join_type": { "type": ["string", "null"], "enum": ["left", "inner", "exact", null] },
        "preserve_spectrum_order": { "type": ["boolean", "null"] },
        "allow_unmatched_spectra": { "type": ["boolean", "null"] },
        "allow_unmatched_labels": { "type": ["boolean", "null"] },
        "duplicate_policy": { "type": ["string", "null"], "enum": ["blocked", "first", "last", null] },
        "missing_label_policy": { "type": ["string", "null"], "enum": ["blocked", "warning", "allow", null] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
